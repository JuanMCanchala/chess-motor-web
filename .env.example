# Motor a usar: "stockfish" (más potente, por defecto) o "kallpa" (motor propio)
ENGINE_KIND=stockfish

# Ruta al binario de Stockfish (UCI)
STOCKFISH_PATH=C:\ruta\a\stockfish.exe
# Hilos y tabla hash (MB) de Stockfish. Vacío = auto (núcleos-1 / 256 MB)
# STOCKFISH_THREADS=8
# STOCKFISH_HASH=512

# Ruta al motor propio KallpaModulo (solo si ENGINE_KIND=kallpa)
ENGINE_PATH=../chess-motor/Chess_motor/cpp_engine/build/engine_server.exe

# Puerto del servidor web
PORT=3000
